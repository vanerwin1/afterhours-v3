// AfterHours Command Center — Prisma Schema
// Run: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Roles ────────────────────────────────────────────────────────────────────
enum Role {
  super_admin
  admin
  viewer
}

// ── Users ────────────────────────────────────────────────────────────────────
model User {
  id                String    @id @default(cuid())
  email             String    @unique
  emailVerified     DateTime?
  name              String?
  image             String?
  password          String?   // bcrypt hash; null for OAuth-only accounts
  role              Role      @default(viewer)
  twoFactorEnabled  Boolean   @default(false)
  twoFactorSecret   String?   // base32 TOTP secret (encrypted at rest in prod)
  banned            Boolean   @default(false)
  bannedAt          DateTime?
  bannedBy          String?
  bannedReason      String?
  lastLoginAt       DateTime?
  lastLoginIp       String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  auditLogs     AuditLog[]
  loginAttempts LoginAttempt[]

  @@index([email])
}

// ── Auth.js (NextAuth v5) adapter tables ─────────────────────────────────────
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  ip           String?
  userAgent    String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Audit Log ─────────────────────────────────────────────────────────────────
model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  userEmail String
  action    String   // e.g. "user.ban", "stripe.refund", "settings.maintenance_toggle"
  resource  String?  // e.g. "User:usr_xxx", "Payment:pi_xxx"
  details   Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@index([action])
}

// ── Login Attempts (security) ────────────────────────────────────────────────
model LoginAttempt {
  id         String   @id @default(cuid())
  email      String
  ip         String
  userAgent  String?
  success    Boolean
  userId     String?
  failReason String?  // "invalid_password", "user_banned", "2fa_failed"
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([ip])
  @@index([email])
  @@index([createdAt])
}

// ── Settings ─────────────────────────────────────────────────────────────────
model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
  updatedBy String?  // userId
}

// ── Feature Flags ─────────────────────────────────────────────────────────────
model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?
  enabled     Boolean  @default(false)
  rolloutPct  Int      @default(100) // 0-100 percent rollout
  updatedBy   String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}

// ── Announcements ─────────────────────────────────────────────────────────────
model Announcement {
  id          String    @id @default(cuid())
  content     String
  type        String    @default("info") // info | warning | success | error
  active      Boolean   @default(true)
  dismissible Boolean   @default(true)
  scheduledAt DateTime?
  expiresAt   DateTime?
  createdBy   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ── API Keys ──────────────────────────────────────────────────────────────────
model ApiKey {
  id            String    @id @default(cuid())
  name          String
  keyHash       String    @unique // SHA-256 of the full key
  keyPrefix     String    // first 8 chars for display ("ahk_sk_1...")
  role          Role      @default(viewer)
  scopes        String[]  // e.g. ["read:payments", "write:settings"]
  createdBy     String    // userId
  lastUsedAt    DateTime?
  lastUsedIp    String?
  revokedAt     DateTime?
  revokedBy     String?
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())

  @@index([keyHash])
}

// ── Webhook Events Log ────────────────────────────────────────────────────────
model WebhookEvent {
  id          String   @id @default(cuid())
  source      String   // "stripe"
  eventId     String   @unique // Stripe event ID for idempotency
  eventType   String
  payload     Json
  processed   Boolean  @default(false)
  error       String?
  processedAt DateTime?
  createdAt   DateTime @default(now())

  @@index([source])
  @@index([eventType])
  @@index([createdAt])
}

// ── Uptime Checks ─────────────────────────────────────────────────────────────
model UptimeCheck {
  id         String   @id @default(cuid())
  url        String
  name       String
  status     Int?
  responseMs Int?
  success    Boolean
  error      String?
  checkedAt  DateTime @default(now())

  @@index([url])
  @@index([checkedAt])
}

// ── Notifications ─────────────────────────────────────────────────────────────
model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  type      String   @default("info") // info | warning | error | success
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}
