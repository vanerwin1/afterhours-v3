# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:password@localhost:5432/afterhours_admin?schema=public"

# ── Auth.js v5 (NextAuth) ──────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-32-char-secret-here"

# Google OAuth — create at console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ── Stripe ────────────────────────────────────────────────────────────────────
# Secret key from dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."

# Webhook signing secret from dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── Upstash Redis (rate limiting + caching) ────────────────────────────────────
# Create free instance at upstash.com
UPSTASH_REDIS_URL="https://your-redis.upstash.io"
UPSTASH_REDIS_TOKEN="your-upstash-token"

# ── Resend (email notifications) ──────────────────────────────────────────────
# API key from resend.com
RESEND_API_KEY="re_..."
# From address (must be a verified domain in Resend)
RESEND_FROM="AfterHours Admin <admin@yourdomain.com>"

# ── Slack Notifications ────────────────────────────────────────────────────────
# Create at api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL="https://hooks.slack.com/services/..."

# ── Security ──────────────────────────────────────────────────────────────────
# Comma-separated list of allowed IP addresses (leave empty to allow all)
# e.g. "192.168.1.1,10.0.0.0/8"
ALLOWED_IPS=""

# ── Fallback Auth (used when DB is unreachable, e.g. on Vercel) ──────────────
# Allows login even when Prisma can't connect to Supabase from Vercel
ADMIN_FALLBACK_EMAIL="admin@afterhours.ai"
# bcrypt hash of your admin password (rounds=12)
# Generate: node -e "const b=require('bcryptjs'); b.hash('password',12).then(console.log)"
ADMIN_FALLBACK_HASH='$2a$12$...'
ADMIN_FALLBACK_ROLE="super_admin"

# ── App ───────────────────────────────────────────────────────────────────────
# Public URL of this admin app (used for OAuth callbacks, email links)
NEXT_PUBLIC_APP_URL="http://localhost:3340"

# Auth.js needs to know its public URL so login redirects work
NEXTAUTH_URL="http://localhost:3340"

# Trust the host header from tunnel/proxy (required for Auth.js v5 behind a proxy)
AUTH_TRUST_HOST="true"

# Port (default 3340 — dev server)
PORT=3340

# ── AfterHours API Servers (for cross-server controls) ────────────────────────
# The main site's agent server (for maintenance mode, bookings, etc.)
AFTERHOURS_AGENT_URL="http://localhost:3335"
AFTERHOURS_AGENT_ADMIN_KEY="your-admin-key-from-agent-server-env"
